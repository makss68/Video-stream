{
  "name": "stream-viewer",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "prebuild:android": "expo prebuild --platform android --clean && echo 'android.kotlinVersion=1.9.24' >> android/gradle.properties",
    "build:tv:apk": "cd android && ./gradlew assembleRelease",
    "build:tv:apk:debug": "cd android && ./gradlew assembleDebug",
    "build:tv:aab": "cd android && ./gradlew bundleRelease",
    "build:tv:fresh:apk": "npm run prebuild:android && npm run build:tv:apk",
    "build:tv:fresh:debug": "npm run prebuild:android && npm run build:tv:apk:debug"
  },
  "overrides": {
    "expo-font": "~13.0.4"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "^14.0.4",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "axios": "^1.7.0",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-linear-gradient": "~14.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "expo-video": "~2.0.0",
    "hls.js": "^1.6.15",
    "react": "18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "0.76.3",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/hls.js": "^0.13.3",
    "@types/react": "~18.3.12",
    "typescript": "^5.3.0"
  },
  "private": true
}
